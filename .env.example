PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@db:5432/ghnotify

# GitHub API (optional — raises rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=ghp_your_token_here

# Redis
REDIS_URL=redis://redis:6379
REDIS_TTL=600

# SMTP (e.g. Gmail with App Password, Mailtrap for dev)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM="GitHub Notifier <noreply@example.com>"

# Base URL used to build confirm/unsubscribe links in emails
APP_BASE_URL=http://localhost:3000

# Cron schedule (default: every 5 minutes)
CRON_SCHEDULE=*/5 * * * *

# API key for X-API-Key header (leave empty to disable auth in dev)
API_KEY=your_secret_api_key

NODE_ENV=production
