{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": ["ES2020"],
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": false,
        "sourceMap": true,
        "types": ["jest", "node"],
        "paths": {
            "@config/*": ["./src/config/*"],
            "@domains/*": ["./src/domains/*"],
            "@utilities/*": ["./src/utilities/*"],
            "@constants/*": ["./src/constants/*"],
            "@middlewares/*": ["./src/middlewares/*"],
            "@exceptions/*": ["./src/exceptions/*"],
            "@db/*": ["./src/db/*"]
        }
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "tests"]
}
