{
    "name": "github-release-notifier",
    "version": "1.0.0",
    "description": "API service for subscribing to GitHub repository release notifications via email",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc && tsc-alias",
        "start": "node dist/index.js",
        "dev": "ts-node -r tsconfig-paths/register src/index.ts",
        "test": "jest --runInBand",
        "test:cov": "jest --runInBand --coverage",
        "test:unit": "jest --runInBand --coverage --testPathIgnorePatterns='<rootDir>/src/test/integration' --testPathIgnorePatterns='<rootDir>/tests/e2e'",
        "test:integration": "jest src/test/integration --runInBand --forceExit",
        "test:e2e": "docker compose -f docker-compose.e2e.yml down -v; docker compose -f docker-compose.e2e.yml up -d --build --wait && npx playwright test; docker compose -f docker-compose.e2e.yml down -v",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "husky"
    },
    "dependencies": {
        "axios": "^1.7.2",
        "dotenv": "^17.4.1",
        "eslint-config-prettier": "^10.1.8",
        "express": "^5.0.0",
        "ioredis": "^5.4.1",
        "morgan": "^1.10.0",
        "node-cron": "^3.0.3",
        "nodemailer": "^6.9.14",
        "pg": "^8.12.0",
        "prom-client": "^15.1.3",
        "swagger-ui-express": "^5.0.1",
        "yamljs": "^0.3.0"
    },
    "devDependencies": {
        "@playwright/test": "^1.60.0",
        "@testcontainers/postgresql": "^11.14.0",
        "@types/express": "^5.0.0",
        "@types/jest": "^29.5.14",
        "@types/morgan": "^1.9.9",
        "@types/node": "^24.12.2",
        "@types/node-cron": "^3.0.11",
        "@types/nodemailer": "^6.4.15",
        "@types/pg": "^8.11.6",
        "@types/supertest": "^6.0.2",
        "@types/swagger-ui-express": "^4.1.6",
        "@types/yamljs": "^0.2.34",
        "eslint": "^9.39.4",
        "globals": "^16.2.0",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "nodemon": "^3.1.4",
        "prettier": "3.8.3",
        "supertest": "^7.0.0",
        "testcontainers": "^11.14.0",
        "ts-jest": "^29.1.5",
        "ts-node": "^10.9.2",
        "tsc-alias": "^1.8.17",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.34.1"
    }
}
